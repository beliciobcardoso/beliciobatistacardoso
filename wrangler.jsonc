{
  "$schema": "node_modules/wrangler/config-schema.json",
  "build": {
    "command": "pnpm build"
  },
  "name": "beliciobatistacardoso",
  "compatibility_date": "2026-04-09",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": ".open-next/worker.js",
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "beliciobatistacardoso"
    }
  ],
  "env": {
    "development": {
      "main": "vinext/server/app-router-entry",
      "assets": {
        "not_found_handling": "none"
      }
    },
    "production": {
      "main": ".open-next/worker.js",
      "assets": {
        "directory": ".open-next/assets",
        "binding": "ASSETS"
      },
      "services": [
        {
          "binding": "WORKER_SELF_REFERENCE",
          "service": "beliciobatistacardoso"
        }
      ]
    }
  },
  "images": {
    "binding": "IMAGES"
  },
  "observability": {
    "enabled": true
  }
}
